# R/RStudio
.Rproj.user/
.Rhistory
.RData
.Ruserdata
*.Rcheck/
*.tar.gz

# Local editor and OS metadata
.DS_Store
.positai/
# Ignore everything under .claude/ (local session state,
# settings.local.json, etc.) EXCEPT the shared, committed permission
# allowlist in settings.json, the shared slash commands, and the
# ai-config skills symlink (points at the .ai-config submodule).
.claude/*
!.claude/settings.json
!.claude/commands
!.claude/commands/**
!.claude/skills
/.luarc.json

# Quarto and render artifacts
/.quarto/
/_book/
/_site/
/_slides/*
!/_slides/images/
!/_slides/images/**
/_handouts/
/_freeze/
*_cache/
*_files/
site_libs/
*.html
# Source HTML partial (injected via include-after-body), not rendered output.
!_mobile-toc.html
*.pdf
*-handout.docx
*.aux
*.log
*.tex
*.toc
*.rmarkdown
*.idx
*.ilg
*.ind
Intro-to-GLMs.pdf
test.qmd
rsconnect/

# Rendered Markdown is noisy, but keep hand-written project docs visible.
*.md
!README.md
!CLAUDE.md
!CODE_OF_CONDUCT.md
!LICENSE.md
# Keep the shared .claude slash commands (their .md files override *.md above).
!.claude/commands/**
!SUBMODULE_SETUP.md
!.github/**/*.md

**/*.quarto_ipynb

# renv files
renv/library/
renv/local/
renv/cellar/
renv/lock/
renv/python/
renv/sandbox/
renv/staging/
.aider*

# Python bytecode
**/__pycache__/
*.pyc
